{
  "name": "contributte/api-router-skeleton",
  "description": "Nette project example for contributte/api-router library by @f3l1x and @paveljanda",
  "keywords": [
    "php",
    "nette",
    "contributte",
    "sandbox",
    "project",
    "skeleton",
    "api"
  ],
  "license": "MIT",
  "type": "project",
  "require": {
    "php": ">=8.4",

    "contributte/application": "^0.6.0",
    "contributte/bootstrap": "^0.7.0",
    "contributte/cache": "^0.7.0",
    "contributte/di": "^0.6.0",
    "contributte/http": "^0.5.0",
    "contributte/security": "^0.5.0",
    "contributte/utils": "^0.7.0",
    "contributte/tracy": "^0.7.0",

    "contributte/api-router": "^7.0"
  },
  "require-dev": {
    "contributte/qa": "^0.4",
    "contributte/tester": "^0.4",
    "contributte/phpstan": "^0.3"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
